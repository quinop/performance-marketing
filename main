import feedparser
import requests
import logging
import os
import traceback
import time
from datetime import datetime
from google import genai
from google.genai import types

# --- 1. CONFIGURATION ---
GEMINI_KEY = os.environ.get('GEMINI_API_KEY')
TELEGRAM_TOKEN = os.environ.get('TELEGRAM_BOT_TOKEN')
CHAT_ID = os.environ.get('TELEGRAM_CHAT_ID') 

client = genai.Client(api_key=GEMINI_KEY)
MEMORY_FILE = "sent_urls.txt"

# --- 2. PERFORMANCE MARKETING SOURCES ---
# We focus on platform-specific news, industry-leading blogs, and tool updates.
AD_PLATFORM_SOURCES = {
    "Google Ads Blog": "https://blog.google/products/ads-commerce/rss/",
    "Search Engine Land (PPC)": "https://searchengineland.com/library/ppc/feed",
    "Social Media Today (Meta/TikTok)": "https://www.socialmediatoday.com/feeds/news/",
    "Marketing Dive": "https://www.marketingdive.com/feeds/news/",
    "Search Engine Journal": "https://www.searchenginejournal.com/feed/"
}

TOOL_ASO_SOURCES = {
    "AppTweak Blog": "https://www.apptweak.com/en/aso-blog/feed",
    "Sensor Tower Blog": "https://sensortower.com/blog/rss",
    "Business of Apps": "https://www.businessofapps.com/feed/",
    "MobileDevMemo": "https://mobiledevmemo.com/feed/"
}

logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(levelname)s - %(message)s")

# --- 3. UTILITIES ---
def load_sent_urls():
    if not os.path.exists(MEMORY_FILE): return set()
    try:
        with open(MEMORY_FILE, "r") as f: 
            return set(line.strip() for line in f if line.strip())
    except Exception as e:
        logging.error(f"Failed to read memory: {e}")
        return set()

def save_sent_urls(urls):
    if not urls: return
    try:
        existing = list(load_sent_urls())
        # Maintain a rolling window of the last 1000 URLs to prevent the file from growing infinitely
        combined = list(urls) + [u for u in existing if u not in urls]
        with open(MEMORY_FILE, "w") as f:
            for url in combined[:1000]: 
                f.write(f"{url}\n")
    except Exception as e:
        logging.error(f"Failed to save memory: {e}")

def fetch_data(source_dict):
    sent_urls = load_sent_urls()
    items, new_urls = [], []
    for name, url in source_dict.items():
        try:
            resp = requests.get(url, timeout=15)
            feed = feedparser.parse(resp.content)
            for entry in feed.entries[:8]: # Check top 8 per source
                if entry.link not in sent_urls:
                    # Capture title + a bit of description for better AI context
                    summary_text = entry.get('summary', '')[:300]
                    items.append({"source": name, "title": entry.title, "link": entry.link, "desc": summary_text})
                    new_urls.append(entry.link)
        except Exception as e: 
            logging.error(f"Fetch failed for {name}: {e}")
    return items, new_urls

# --- 4. SUMMARIZATION ---
def get_summary_safe(items, system_instruction):
    if not items: return None
    # Provide the AI with both Title and Description for more accurate "top-line" summaries
    text_blob = "\n".join([f"- [{i['source']}] {i['title']}: {i['desc']}" for i in items])
    
    models_to_try = ["gemini-2.0-flash", "gemini-1.5-flash"]
    
    for model_id in models_to_try:
        try:
            response = client.models.generate_content(
                model=model_id,
                contents=[f"Context: {text_blob}"],
                config=types.GenerateContentConfig(system_instruction=system_instruction)
            )
            return response.text
        except Exception as e:
            logging.warning(f"Model {model_id} failed: {e}")
            continue
    return None

def send_to_telegram(message):
    if not CHAT_ID or not TELEGRAM_TOKEN: return
    url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage"
    # Telegram has a 4096 character limit
    payload = {"chat_id": CHAT_ID, "text": message[:4090], "parse_mode": "HTML", "disable_web_page_preview": True}
    try:
        r = requests.post(url, data=payload, timeout=15)
        r.raise_for_status()
    except Exception as e:
        logging.error(f"Telegram failed: {e}")

# --- 5. EXECUTION ---
def run_agent():
    logging.info("Starting Performance Marketing scan...")
    
    ad_items, ad_urls = fetch_data(AD_PLATFORM_SOURCES)
    tool_items, tool_urls = fetch_data(TOOL_ASO_SOURCES)

    if not ad_items and not tool_items:
        logging.info("No new industry changes detected.")
        return

    # Summarize Ad Platform Changes
    ad_summary = get_summary_safe(
        ad_items, 
        "You are a Performance Marketing expert. Summarize the most important updates regarding Meta, Google, TikTok, or Apple Ads. "
        "Focus on 'top-line' changes (algorithm updates, new ad formats, tracking changes). "
        "Format: • <b>Platform/Source</b>: Brief impact-focused summary (1 sentence)."
    )

    # Summarize Tool & ASO Changes
    tool_summary = get_summary_safe(
        tool_items, 
        "You are an ASO and MarTech expert. Summarize updates for tools like AppTweak, Sensor Tower, or general mobile industry shifts. "
        "Format: • <b>Tool/Source</b>: Brief impact-focused summary (1 sentence)."
    )

    if ad_summary or tool_summary:
        final_msg = f"<b>🚀 PERFORMANCE MARKETING DAILY</b>\n<i>{datetime.now().strftime('%Y-%m-%d')}</i>\n\n"
        
        if ad_summary:
            final_msg += f"<b>📡 AD PLATFORMS & CHANNELS</b>\n{ad_summary}\n\n"
        
        if tool_summary:
            final_msg += f"<b>🛠️ TOOLS & MARKET INTELLIGENCE</b>\n{tool_summary}\n\n"
        
        final_msg += "<i>Source URLs saved to memory.</i>"

        send_to_telegram(final_msg)
        save_sent_urls(ad_urls + tool_urls)
    else:
        logging.error("AI failed to process the news items.")

if __name__ == "__main__":
    run_agent()
